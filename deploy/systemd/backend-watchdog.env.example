INSTALL_DIR=/opt/akfa-vpn
COMPOSE_FILE=/opt/akfa-vpn/docker-compose.yml
PROJECT_DIR=/opt/akfa-vpn
BACKEND_SERVICE=backend
HEALTH_URL=http://127.0.0.1:8000/health
FAIL_THRESHOLD=3
CONNECT_TIMEOUT=2
MAX_TIME=5
COOLDOWN_SECONDS=180
STATE_DIR=/var/lib/akfa-backend-watchdog
LOG_FILE=/var/log/akfa-backend-watchdog.log
