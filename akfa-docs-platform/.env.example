NODE_ENV=production
HOSTNAME=127.0.0.1
PORT=6876
SITE_URL=https://DOCS_DOMAIN
DATA_DIR=/opt/akfa-docs-platform/data
DOWNLOADS_DIR=/opt/akfa-downloads
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=ADMIN_EMAIL
ADMIN_PASSWORD=replace-with-temporary-admin-password
MAX_UPLOAD_MB=5
MAX_DOWNLOAD_MB=200
ALLOWED_DOWNLOAD_EXTENSIONS=apk,exe,dmg,zip,msi,pkg
